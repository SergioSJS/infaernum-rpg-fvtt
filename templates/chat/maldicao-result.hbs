<div class="infaernum-chat-message infaernum-chat-message--maldicao">
  <div class="chat-header">
    <span class="cavaleiro-badge {{cavaleiro}}">{{infaernum-cavaleiro-label cavaleiro}}</span>
    encontrou <strong>{{actor.name}}</strong>
  </div>

  <div class="maldicao-indice">Maldição #{{indice}}</div>

  <blockquote class="maldicao-texto">
    {{descricao}}
  </blockquote>

  <p class="chat-aviso">
    Maldição permanente adicionada. Desgraças zeradas.
    Próxima acumulação de 6 desgraças = <strong>MORTE</strong>.
  </p>
</div>
