<div class="inf-dialog inf-dialog--cavaleiro">

  <p class="dialog-aviso-maior">
    ☠ <strong>{{actor.name}}</strong> acumulou 6 desgraças — Cavaleiro aparece!
  </p>

  <div class="field-group">
    <label>Cavaleiro</label>
    <select name="cavaleiro">
      <option value="" disabled selected>— Escolha ou role 1d4 —</option>
      {{#each cavaleiros as |c|}}
        <option value="{{c}}">{{infaernum-cavaleiro-label c}}</option>
      {{/each}}
    </select>
  </div>

  <div class="field-group">
    <label>Maldição (1d6)</label>
    <select name="indice">
      <option value="aleatorio" selected>Aleatório (rolar 1d6)</option>
      <option value="1">1</option>
      <option value="2">2</option>
      <option value="3">3</option>
      <option value="4">4</option>
      <option value="5">5</option>
      <option value="6">6</option>
    </select>
  </div>

  <p class="dialog-regra">
    Desgraças serão zeradas. Personagem ganha maldição permanente.
  </p>

</div>
