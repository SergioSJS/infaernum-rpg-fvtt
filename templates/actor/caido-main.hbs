<section class="sheet-body">
  <div class="field-group">
    <label>{{localize "INFAERNUM.Caido.Dificuldade"}}</label>
    <input type="number" name="system.dificuldade" value="{{system.dificuldade}}" min="0" />
  </div>
  <div class="field-group">
    <label>{{localize "INFAERNUM.Caido.DificuldadeAtual"}}</label>
    <input type="number" name="system.dificuldade_atual" value="{{system.dificuldade_atual}}" min="0" />
  </div>
  <div class="field-group">
    <label>{{localize "INFAERNUM.Caido.Aparencia"}}</label>
    <input type="text" name="system.aparencia" value="{{system.aparencia}}" />
  </div>
  <div class="field-group">
    <label>{{localize "INFAERNUM.Caido.Descricao"}}</label>
    <textarea name="system.descricao" rows="5" {{#unless editable}}readonly{{/unless}}>{{system.descricao}}</textarea>
  </div>

  <div class="caido-controls">
    <button type="button" data-action="reduzirDificuldade" data-reducao="1">Façanha (−1)</button>
    <button type="button" data-action="reduzirDificuldade" data-reducao="2">Milagre (−2)</button>
  </div>
</section>
